# Plantry environment variables
# Copy to .env and fill in values before running.

# Server
PLANTRY_PORT=8080
PLANTRY_DB_PATH=/data/plantry.db
PLANTRY_LOG_LEVEL=info          # debug | info | warn | error
PLANTRY_IMAGE_PATH=/data/images
PLANTRY_DEV_MODE=false

# Encryption (optional) — enables encrypted storage of API keys in the DB.
# Generate with: openssl rand -base64 32
PLANTRY_SECRET_KEY=

# AI provider (optional) — leave blank to disable AI features.
# Supported: openai | anthropic | fake
PLANTRY_AI_PROVIDER=
PLANTRY_AI_MODEL=
PLANTRY_AI_API_KEY=
PLANTRY_AI_RATE_LIMIT_PER_MIN=10

# USDA Food Data Central (optional) — enables nutritional lookup.
# Get a free key at https://fdc.nal.usda.gov/api-key-signup.html
PLANTRY_FDC_API_KEY=
